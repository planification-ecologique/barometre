{
  "name": "barometre",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "download-grist-csvs": "node scripts/download-grist-csvs.js",
    "download-irpe-cache": "node scripts/download-irpe-cache.js",
    "serve": "vue-cli-service serve",
    "lint": "npm run lint:eslint",
    "lint:eslint": "eslint \"src/**/*.{js,vue}\" \"tests/**/*.js\"",
    "lint:format": "prettier --check \"src/**/*.{js,vue,css,scss}\" \"tests/**/*.js\"",
    "test:unit": "vue-cli-service test:unit",
    "build": "vue-cli-service build",
    "build_qualif": "vue-cli-service build --mode qualif",
    "build_prod": "vue-cli-service build",
    "watch": "vue-cli-service build --watch",
    "deploy": "npm run build_qualif && cd dist && cp index.html 200.html && cd .. && surge ./dist -d barometre-sgpe.surge.sh",
    "prebuild:firebase": "npm run download-grist-csvs && npm run download-irpe-cache",
    "build:firebase": "npm run build_prod && cd dist && cp index.html 200.html && cd ..",
    "predeploy:functions": "npm install --prefix functions",
    "deploy:firebase": "npm run predeploy:functions && npm run build:firebase && firebase deploy --only hosting,functions",
    "deploy:firebase:prod": "npm run predeploy:functions && npm run build:firebase && firebase deploy --only hosting,functions --project barometre-sgpe",
    "prebuild:pages": "npm run download-grist-csvs && npm run download-irpe-cache",
    "build:pages": "vue-cli-service build && cp dist/index.html dist/404.html",
    "deploy:pages": "npm run build:pages"
  },
  "dependencies": {
    "@gouvfr/dsfr": "^1.11.2",
    "axios": "^1.6.2",
    "chart.js": "^2.9.4",
    "chartjs-plugin-annotation": "^0.5.7",
    "chroma-js": "^2.4.2",
    "core-js": "^3.30.2",
    "d3-scale": "^4.0.2",
    "eslint-plugin-vue": "^9.19.2",
    "mobile-device-detect": "^0.4.3",
    "papaparse": "^5.4.1",
    "patternomaly": "^1.3.2",
    "remixicon": "^4.9.1",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "vue": "^2.7.14",
    "vue-custom-element": "^3.3.0",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-unit-jest": "^5.0.9",
    "@vue/cli-service": "^5.0.8",
    "@vue/test-utils": "^1.3.6",
    "@vue/vue2-jest": "^27.0.0",
    "prettier": "3.1.0",
    "vue-template-compiler": "^2.7.14"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
