# Copier ce fichier en `.env` pour le développement local :
#   cp .env.example .env
#
# Variables injectées au build (préfixe VUE_APP_ requis par Vue CLI).

# dev | qualif | prod
VUE_APP_ENV=dev

# Préfixe URL — laisser vide pour prod (domaine custom GitHub Pages).
# Previews PR : /pr/<numéro>/
VUE_APP_PREFIX_PATH=

# Domaine Eulerian / analytics
# Production : phdd.barometre.planification-ecologique.gouv.fr
VUE_APP_TRACKING=

# Token Bearer pour l'API Écolab (indicateurs régionaux)
# Demander un token auprès de l'équipe Écolab — ne jamais committer de valeur réelle.
VUE_APP_ECOLAB_API_TOKEN=
